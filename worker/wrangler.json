{
  "$schema": "https://schemas.cloudflare.com/wrangler/v3.json",
  "name": "flask-app-worker",
  "main": "index.js",
  "compatibility_date": "2026-04-09",
  "containers": [
    {
      "binding": "CONTAINER_DO",
      "class": "FlaskContainer",
      "image": {
        "context": "../flask_app",
        "dockerfile": "Dockerfile"
      }
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "CONTAINER_DO",
        "class": "FlaskContainer"
      }
    ]
  }
}